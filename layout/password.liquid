<!doctype html>
<html class="no-js"
  lang="{{ request.locale.iso_code }}"
  dir="{% if settings.typography_rtl %}rtl{% else %}ltr{% endif %}"
  {% if request.design_mode %}
    data-design-mode
  {% endif %}
>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.general_accent_color }}">
    <link rel="canonical" href="{{ canonical_url }}">

    <script src="{{ 'es-module-shims.js' | asset_url }}" async></script>
    {%- liquid
      render 'importmap'
      render 'js-variables'
      render 'asset-tag', asset: 'main.js'

      if request.page_type contains 'customers/'
        render 'asset-tag', asset: 'customers.js'
      endif
    -%}

    {%- if settings.favicon != blank -%}
      <link rel="apple-touch-icon" sizes="180x180" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>{{ page_title }}</title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {%- render 'meta-tags' -%}

    {{ content_for_header }}

    {%- liquid
      render 'css-variables'
      render 'asset-tag', asset: 'main.css', preload_stylesheet: true
      render 'asset-tag', asset: 'main-password.css', preload_stylesheet: true
    -%}
    
    {% comment %}theme-check-disable AssetPreload{% endcomment %}
    {%- unless settings.typography_body_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.typography_body_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
    {%- unless settings.typography_headings_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.typography_headings_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
    {%- unless settings.typography_navigation_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.typography_navigation_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}
    {% comment %}theme-check-enable AssetPreload{% endcomment %}
  </head>

  <body id="{{ page_title | handle }}"
    class="font-body bg-section-background"
    data-page-type="{{ request.page_type }}">
    <a class="skip-to-content-link button sr-only" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>
    {% section 'main-password-header' %}

    <main id="MainContent" class="password-main bg-primary-background" role="main">
      {{ content_for_layout }}
    </main> 

  <!-- District v7.1.1 -->
  </body>
</html>