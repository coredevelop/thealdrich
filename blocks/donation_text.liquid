{% assign uid = block.id | replace: '_', '' | downcase %}

{% style %}
  .donation-text-{{ uid }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
  }

  .donation-text__heading-{{ uid }} {
    margin: 0 0 12px;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 500;
    line-height: 1.3;
    color: {{ block.settings.heading_color }};
  }

  .donation-text__body-{{ uid }} {
    font-size: {{ block.settings.body_size }}px;
    line-height: 1.6;
  }

  .donation-text__body-{{ uid }} > *:first-child {
    margin-top: 0;
  }

  .donation-text__body-{{ uid }} > *:last-child {
    margin-bottom: 0;
  }

  .donation-text__body-{{ uid }} a {
    color: inherit;
  }

  @media screen and (max-width: 749px) {
    .donation-text-{{ uid }} {
      width: 100%;
      padding: {{ block.settings.padding_top | times: 0.75 }}px {{ block.settings.padding_horizontal | times: 0.75 }}px {{ block.settings.padding_bottom | times: 0.75 }}px;
    }

    .donation-text__heading-{{ uid }} {
      font-size: {{ block.settings.heading_size | times: 0.85 | round }}px;
    }
  }
{% endstyle %}

<div class="donation-text-{{ uid }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="donation-text__heading-{{ uid }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.body != blank %}
    <div class="donation-text__body-{{ uid }}">{{ block.settings.body }}</div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Donation text",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to hide.",
      "default": "Make a Gift"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Text",
      "default": "<p>Your support helps The Aldrich present bold contemporary art and education programs.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding sides",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#333333"
    }
  ],
  "presets": [
    {
      "name": "Donation text"
    }
  ]
}
{% endschema %}
