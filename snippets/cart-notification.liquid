{%- if settings.cart_type == 'preview' -%}
  <cart-notification id="cart-notification" class="cart-notification text-xs"
    aria-modal="true" aria-label="{{ 'general.cart.item_added' | t }}"
    role="dialog" tabindex="-1">
    <div class="cart-notification__container">
      <div class="cart-notification__title">
        <span>{{ 'general.cart.item_added' | t }}</span>
        <button id="CollectionDrawerModalClose-{{ block.id }}" type="button"
          class="cart-notification__close"
          aria-label="{{ 'accessibility.close' | t }}">{% render 'icon-ui-close' %}</button>
      </div>
      <div id="cart-notification-product" class="cart-notification__product"></div>
      <div id="cart-notification-links" class="cart-notification__links">
        <a href="{{ routes.cart_url }}" class="cart-notification__cart">{{ 'general.cart.view' | t: count: cart.item_count }}</a>
        <form action="{{ routes.cart_url }}" method="post" id="cart-notification-form">
          <button class="cart-notification__checkout" name="checkout">{{ 'sections.cart.checkout' | t }}</button>
        </form>
        <button type="button" class="cart-notification__continue">{{ 'general.continue_shopping' | t }}</button>
      </div>
    </div>
  </cart-notification>
{%- endif -%}