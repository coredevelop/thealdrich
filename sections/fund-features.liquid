<style>
  [data-section-id="{{ section.id }}"] {
    --fund-image-gap: {{ section.settings.image_gap }}px;
    --fund-block-gap: {{ section.settings.block_gap }}px;
  }

  {%- if section.settings.section_padding == false -%}
    [data-section-id="{{ section.id }}"].fund-features {
      padding-top: 0;
      padding-bottom: 0;
      border-bottom: 0;
    }
  {%- endif -%}

  [data-section-id="{{ section.id }}"] .fund-features__inner {
    max-width: {{ section.settings.content_max_width }}px;
    margin-left: auto;
    margin-right: auto;
  }

  [data-section-id="{{ section.id }}"] .fund-features__list {
    display: flex;
    flex-direction: column;
    gap: var(--fund-block-gap);
  }

  [data-section-id="{{ section.id }}"] .fund-feature__heading {
    margin: 0 0 20px;
    font-weight: 600;
    line-height: 1.3;
  }

  [data-section-id="{{ section.id }}"] .fund-feature__images {
    display: grid;
    gap: var(--fund-image-gap);
    margin-bottom: 24px;
  }

  [data-section-id="{{ section.id }}"] .fund-feature__image-wrap {
    width: 100%;
    overflow: hidden;
    line-height: 0;
    background-color: {{ section.settings.image_placeholder_color }};
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  [data-section-id="{{ section.id }}"] .fund-feature__image-wrap img,
  [data-section-id="{{ section.id }}"] .fund-feature__image-wrap .placeholder-svg {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: {{ section.settings.image_ratio }};
    object-fit: cover;
  }

  [data-section-id="{{ section.id }}"] .fund-feature__link {
    display: inline-block;
    margin-top: 4px;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
    color: inherit;
  }

  @media screen and (max-width: 749px) {
    [data-section-id="{{ section.id }}"] .fund-feature__images {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<div
  class="fund-features px-rail py-section border-b border-primary-section-border"
  data-section-id="{{ section.id }}"
  data-section-type="fund-features"
>
  <div class="fund-features__inner max-w-screen mx-auto">
    {%- if section.settings.title != blank -%}
      <h2 class="fund-features__title text-2xl md:text-3xl pb-6">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    <div class="fund-features__list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign image_count = 0
          if block.settings.image_1 != blank
            assign image_count = image_count | plus: 1
          endif
          if block.settings.image_2 != blank
            assign image_count = image_count | plus: 1
          endif
          if block.settings.image_3 != blank
            assign image_count = image_count | plus: 1
          endif
          assign column_count = image_count | at_least: 1
          assign img_sizes = '(max-width: 749px) 100vw, calc(100vw / ' | append: column_count | append: ')'
        -%}

        <div class="fund-feature" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h3 class="fund-feature__heading text-xl md:text-2xl">{{ block.settings.heading | escape }}</h3>
          {%- endif -%}

          {%- if image_count > 0 -%}
            <div
              class="fund-feature__images"
              style="grid-template-columns: repeat({{ column_count }}, 1fr);"
            >
              {%- for i in (1..3) -%}
                {%- liquid
                  case i
                    when 1
                      assign fund_image = block.settings.image_1
                    when 2
                      assign fund_image = block.settings.image_2
                    when 3
                      assign fund_image = block.settings.image_3
                  endcase
                -%}
                {%- if fund_image != blank -%}
                  <div class="fund-feature__image-wrap">
                    {{
                      fund_image
                      | image_url: width: 1200
                      | image_tag:
                        widths: '400, 600, 800, 1200',
                        sizes: img_sizes,
                        loading: 'lazy',
                        alt: fund_image.alt
                    }}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if block.settings.body != blank -%}
            <div class="fund-feature__body rte space-y-4">{{ block.settings.body }}</div>
          {%- endif -%}

          {%- if block.settings.link_label != blank and block.settings.link_url != blank -%}
            <a class="fund-feature__link" href="{{ block.settings.link_url }}">{{ block.settings.link_label | escape }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Fund features",
  "class": "fund-features-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "section_padding",
      "label": "Add section padding",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "info": "Optional heading shown above all funds."
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content width",
      "info": "Maximum width of the funds content on large screens.",
      "min": 600,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1280
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "4/3", "label": "Landscape (4:3)" },
        { "value": "3/2", "label": "Photo (3:2)" },
        { "value": "16/9", "label": "Wide (16:9)" }
      ],
      "default": "4/3"
    },
    {
      "type": "range",
      "id": "image_gap",
      "label": "Gap between images",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "image_placeholder_color",
      "label": "Image placeholder color",
      "default": "#EEEEEE"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "block_gap",
      "label": "Gap between funds",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "fund",
      "name": "Fund",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Exhibitions Fund"
        },
        {
          "type": "header",
          "content": "Images"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3"
        },
        {
          "type": "header",
          "content": "Text"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body text",
          "default": "<p>For 60 years, The Aldrich has offered first museum exhibitions for emerging or mid-career artists, first career surveys of underrepresented artists, and group exhibitions that offer unique perspectives on issues relevant to the world around us.</p><p>A gift to the Exhibitions Fund supports The Aldrich's significant curatorial program, which allows artists to create deep and insightful exhibitions and projects that will have a lasting impact within the field and the world beyond.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "info": "Leave blank to hide the link.",
          "default": "Read more about the Exhibitions Fund here."
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Fund features",
      "blocks": [
        { "type": "fund" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
