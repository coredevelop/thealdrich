<gift-card-recipient 
  class="block mb-4 group"
  data-section-id="{{ section.id }}" 
  data-product-variant-id="{{ product.selected_or_first_available_variant.id }}"
>
  <input
    id="Recipient-checkbox-{{ section.id }}"
    class="recipient__checkbox peer"
    type="checkbox"
    name="properties[__shopify_send_gift_card_to_recipient]"
    disabled
  >
  <label class="recipient__checkbox-label text-primary-text inline-block pl-1 text-base p-0 font-body font-weight-body normal-case tracking-normal"
    for="Recipient-checkbox-{{ section.id }}"><span class="text-sm font-weight-body">Send this as a gift</span></label>
  <p
    id="Recipient-fields-live-region-{{ section.id }}"
    class="sr-only"
    role="status"
  ></p>
  <div
    class="recipient__errors"
    role="alert"
    {% unless form.errors %}
      hidden
    {% endunless %}
  >
    <h3 class="recipient__errors-heading flex items-center mt-1 text-red-600 outline-none" tabindex="-1" autofocus>
      <span class="w-4 h-4 inline-block mr-1">
        {%- render 'icon-ui-error' -%}
      </span>
      <span class="message text-sm">{{ 'templates.contact.form.error_heading' | t }}</span>
    </h3>
    <ul class="text-sm text-section-text-80">
      {%- if form.errors -%}
        {%- for field in form.errors -%}
          <li>
            {%- if field == 'form' -%}
              {{ form.errors.messages[field] }}
            {%- else -%}
              <a href="#Recipient-{{ field }}-{{ section.id }}">
                {{ form.errors.messages[field] }}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>
  
  <div class="recipient__form hidden peer-checked:flex flex-col space-y-3 pt-4">
    <hr>
    <div class="recipient__field">
      <label for="Recipient-email-{{ section.id }}">
        <span>{{ 'recipient.form.email_label' | t }}</span>
      </label>
      <input 
        id="Recipient-email-{{ section.id }}"
        type="email"
        name="properties[Recipient email]"
        value="{{ form.email }}"
        {% if form.errors contains 'email' %}
          aria-invalid="true"
          aria-describedby="Recipient-email-error-{{ section.id }}"
        {% endif %}
      >
      <div
        id="Recipient-email-error-{{ section.id }}"
        class="error__container flex items-center mt-1 text-red-600 {% unless form.errors contains 'email' %}hidden{% endunless %}"
      >
        <span class="w-4 h-4 inline-block mr-1">
          {%- render 'icon-ui-error' -%}
        </span>
        <span class="error__details text-sm">
          {%- if form.errors contains 'email' -%}
            {{ form.errors.messages.email }}.
          {%- endif -%}
        </span>
      </div>
    </div>

    <div class="recipient__field">
      <label for="Recipient-name-{{ section.id }}">
        <span>{{ 'recipient.form.name_label' | t }}</span>
      </label>
      <input 
        id="Recipient-name-{{ section.id }}"
        type="text"
        name="properties[Recipient name]"
        value="{{ form.name }}"
        {% if form.errors contains 'name' %}
          aria-invalid="true"
          aria-describedby="Recipient-name-error-{{ section.id }}"
        {% endif %}
      >
      <div
        id="Recipient-name-error-{{ section.id }}"
        class="error__container flex items-center mt-1 text-red-600 {% unless form.errors contains 'name' %}hidden{% endunless %}"
      >
        <span class="w-4 h-4 inline-block mr-1">
          {%- render 'icon-ui-error' -%}
        </span>
        <span class="error__details text-sm">
          {%- if form.errors contains 'name' -%}
            {{ form.errors.messages.name }}.
          {%- endif -%}
        </span>
      </div>
    </div>

    <div class="recipient__field">
      {%- assign max_chars_message = 200 -%}
      {%- assign max_chars_message_rendered = 'recipient.form.max_characters' | t: max_chars: max_chars_message -%}
      {%- assign message_label_rendered = 'recipient.form.message_label' | t -%}
      <label for="Recipient-message-{{ section.id }}">
        <span>{{ message_label_rendered }}</span>
      </label>
      <textarea 
        id="Recipient-message-{{ section.id }}"
        rows="5"
        name="properties[Message]"
        maxlength="{{ max_chars_message }}"
        aria-label="{{ message_label_rendered }} {{ max_chars_message_rendered }}"
        {% if form.errors contains 'message' %}
          aria-invalid="true"
          aria-describedby="Recipient-message-error-{{ section.id }}"
        {% endif %}
      >
        {{- form.message -}}
      </textarea>
      <label>
        <span>{{ max_chars_message_rendered }}</span>
      </label>

      <div
        id="Recipient-message-error-{{ section.id }}"
        class="error__container flex items-center mt-1 text-red-600 {% unless form.errors contains 'message' %}hidden{% endunless %}"
      >
        <span class="w-4 h-4 inline-block mr-1">
          {%- render 'icon-ui-error' -%}
        </span>
        <span class="error__details text-sm">
          {%- if form.errors contains 'message' -%}
            {{ form.errors.messages.message }}.
          {%- endif -%}
        </span>
      </div>
    </div>

    <div class="recipient__field">
      <label for="Recipient-send-on-{{ section.id }}">
        <span>{{ 'recipient.form.send_on' | t }}</span>
      </label>
      <input 
        id="Recipient-send-on-{{ section.id }}"
        type="date"
        name="properties[Send on]"
        value="{{ form.send_on }}"
        {% if form.errors contains 'send_on' %}
          aria-invalid="true"
          aria-describedby="Recipient-send-on-error-{{ section.id }}"
        {% endif %}
      >
      <div
        id="Recipient-send-on-error-{{ section.id }}"
        class="error__container flex items-center mt-1 text-red-600 {% unless form.errors contains 'send_on' %}hidden{% endunless %}"
      >
        <span class="w-4 h-4 inline-block mr-1">
          {%- render 'icon-ui-error' -%}
        </span>
        <span class="error__details text-sm">
          {%- if form.errors contains 'send_on' -%}
            {{ form.errors.messages.send_on }}.
          {%- endif -%}
        </span>
      </div>
    </div>
  </div>

  <input
    type="hidden"
    name="properties[__shopify_offset]"
    value=""
    id="Recipient-timezone-offset-{{ section.id }}"
    disabled
  >
</gift-card-recipient>