{%- liquid
  render 'asset-tag', asset: 'customer.css'
-%}
<div class="main-login py-section px-rail space-y-6"
  data-section-id="{{ section.id }}"
  data-section-type="main-login">
  <div class="main-login__container text-center mx-auto max-w-screen">

    <div id="recover" tabindex="-1" class="main-login__header mb-6 pb-4 border-b border-primary-section-border outline-none">
      <h1 class="text-3xl md:text-4xl text-center" tabindex="-1">{{ 'customer.recover_password.title' | t }}</h1>
    </div>
    <div class="main-login__content mx-auto">
      <p>{{ 'customer.recover_password.subtext' | t }}</p>
      
      {%- form 'recover_customer_password' -%}
        {% assign recover_success = form.posted_successfully? %}
        <div class="login-form__contain mt-6 text-left max-w-[28rem] mx-auto space-y-4">
          <div class="login-form__field">
            <label for="RecoverEmail">{{ 'customer.login_page.email' | t }}</label>
            <input id="RecoverEmail" type="email"
              autocomplete="email"
              name="email"
              spellcheck="false"
              autocapitalize="off"
              autofocus
              aria-required="true">
          </div>
          {%- if form.errors -%}
            <div class="login-form__message px-4 py-2 bg-primary-secondary-background mx-auto max-w-[28rem] mb-4">
              <div class="outline-none mb-1 flex w-full justify-center" role="alert" tabindex="-1" autofocus><span class="inline-block w-3 mr-1 text-red-600">{% render 'icon-ui-error' %}</span> {{ form.errors.messages['form'] }}</div>
            </div>
          {%- endif -%}

          <div class="flex items-center flex-col justify-center">
            <button class="button button--cta button--solid">
              {{ 'customer.login_page.submit' | t }}
            </button>

            <a href="#login" class="text-sm mt-2 inline-block mb-6 text-primary-text-70 underline hover:text-primary-accent">
              {{ 'customer.login_page.cancel' | t }}
            </a>
          </div>
        </div>        
      {%- endform -%}
      
    </div>

    <div id="login" tabindex="-1" class="main-login__header mb-6 pb-4 border-b border-primary-section-border">
      <h1 class="text-3xl md:text-4xl text-center" tabindex="-1">{{ 'customer.login_page.title' | t }}</h1>
    </div>
    <div class="main-login__content mx-auto">

      {%- if recover_success == true -%}
        <p class="main-login__message">{{ 'customer.recover_password.success' | t }}</p>
      {%- endif -%}

      {%- form 'customer_login', novalidate: 'novalidate' -%}
        {%- if form.errors -%}
          <div class="login-form__message px-4 py-2 bg-primary-secondary-background mx-auto max-w-[28rem] mb-4">
            <div class="outline-none mb-1 flex w-full justify-center" role="alert" tabindex="-1" autofocus><span class="inline-block w-3 mr-1 text-red-600">{% render 'icon-ui-error' %}</span> {{ form.errors | default_errors }}</div>
          </div>
        {%- endif -%}

        <div class="login-form__contain text-left max-w-[28rem] mx-auto space-y-4">
          <div class="login-form__field">
            <label for="CustomerForm-email">{{ 'customer.login_page.email' | t }}</label>
            <input id="CustomerForm-email" type="email"
              autocomplete="email"
              name="customer[email]"
              spellcheck="false"
              autocapitalize="off"
              aria-required="true">
          </div>

          <div class="login-form__field">
            <label for="CustomerForm-password">{{ 'customer.login_page.password' | t }}</label>
            <input id="CustomerForm-password" type="password"
              autocomplete="current-password"
              name="customer[password]"
              aria-required="true">
          </div>

          <div class="flex items-center flex-col justify-center">
            <a href="#recover" class="text-sm inline-block mb-6 text-primary-text-70 underline hover:text-primary-accent">
              {{ 'customer.login_page.forgot_password' | t }}
            </a>

            <button class="button button--cta button--solid">
              {{ 'customer.login_page.sign_in' | t }}
            </button>

            <a href="{{ routes.account_register_url }}" class="text-sm mt-2 inline-block mb-6 text-primary-text-70 underline hover:text-primary-accent">
              {{ 'customer.login_page.create_account' | t }}
            </a>
          </div>
        </div>
        
        {%- if shop.checkout.guest_login -%}
          <div class="max-w-[28rem] mx-auto space-y-4">
            <hr>
            <h2 class="text-2xl">{{ 'customer.login_page.guest_title' | t }}</h2>
            {%- form 'guest_login' -%}
              <button class="button button--cta button--outline">
                {{ 'customer.login_page.guest_continue' | t }}
              </button>
            {%- endform -%}
          </div>
        {%- endif -%}
        
      {%- endform -%}
    </div>

  </div>
</div>