{%- liquid
  render 'asset-tag', asset: 'main-cart.css', preload_stylesheet: true
-%}
<style>
  [data-section-id="{{ section.id }}"] {
    --spacing-section: 2rem;
    border-bottom: 0px;
  }
  [data-shopify-buttoncontainer] {
     justify-content: flex-end;
  }
  @media (max-width: 768px) {
    [data-shopify-buttoncontainer] {
       justify-content: center;
    }
  }
</style>
<div id="main-cart-footer" class="cart-footer block px-rail pt-4 pb-section relative{% if cart == empty %} hidden{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="cart-footer">
  <div class="cart-footer__container mx-auto max-w-screen">
    <div class="cart-footer__grid flex flex-wrap md:flex-nowrap justify-between" dir="ltr">
      {%- if section.settings.show_notes -%}
        <cart-note class="block text-center md:text-left flex-none w-full md:w-1/2 mb-6 md:mb-0" {% if settings.typography_rtl %}dir="rtl"{% else %}dir="ltr"{% endif %}>
          <label class="normal-case text-base font-body tracking-normal pb-2 rtl:text-right" for="Cart-Note">{{ 'sections.cart.note' | t }}</label>
          <textarea class="min-h-[6rem] md:min-h-[10rem] max-w-md md:max-w-none mx-auto text-base md:text-sm bg-primary-secondary-background-50" name="note" form="cart" id="Cart-Note">{{ cart.note }}</textarea>
        </cart-note>
      {%- endif -%}
      <div class="cart-footer__blocks space-y-6 flex-auto text-center md:text-right md:ml-4">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}

            {%- when 'custom_liquid' -%}
              <div class="cart-block__subtotal"  {{ block.shopify_attributes }}>
                {{ block.settings.custom_liquid }}
              </div>

            {%- when 'subtotal' -%}
              <div class="cart-block__subtotal" {{ block.shopify_attributes }}>
                <div class="subtotal">
                  <h3 class="subtotal__heading text-xl md:text-2xl">{{ 'sections.cart.subtotal' | t }}</h3>
                  <p class="subtotal__price text-lg font-weight-body-bolder text-primary-accent flex items-baseline gap-2 justify-center md:justify-end">
                    {%- if cart.cart_level_discount_applications.size > 0 -%}
                      <span class="line-through text-primary-text-70 text-base font-weight-body">{{ cart.original_total_price | money_with_currency }}</span>
                    {%- endif -%}
                    {{ cart.total_price | money_with_currency }}
                  </p>
                </div>

                {%- if cart.cart_level_discount_applications.size > 0 -%}
                  <ul class="discounts" role="list">
                    {%- for discount in cart.cart_level_discount_applications -%}
                      <li class="discounts__discount flex justify-center md:justify-end text-xs font-navigation font-weight-navigation-bolder uppercase">
                        <span class="cart-item__discount-icon w-3 mr-1">{%- render 'icon-ui-discount' -%}</span>
                        {{ discount.title }}
                        (-{{ discount.total_allocated_amount | money }})
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

                <div class="tax-note ml-auto rte rte-sm">
                  {%- if shop.taxes_included and shop.shipping_policy.body != blank -%}
                    {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
                  {%- elsif shop.taxes_included -%}
                    {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
                  {%- elsif shop.shipping_policy.body != blank -%}
                    {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
                  {%- else -%}
                    {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
                  {%- endif -%}
                </div>

              </div>

            {%- when 'discount_code' -%}
              <div class="cart-block__discount-code" {{ block.shopify_attributes }}>
                <cart-discount class="block">
                  <div class="space-y-3 max-w-sm ml-auto">
                    <form class="cart-discount__form flex flex-col sm:flex-row gap-2">
                      <input
                        type="text"
                        name="discount"
                        placeholder="{{ 'sections.cart.discount_placeholder' | t }}"
                        class="flex-1 text-base md:text-sm bg-primary-secondary-background-50 px-2 py-1.5 border border-primary-section-border rounded-none"
                        autocomplete="off">
                      <button
                        type="submit"
                        data-apply-discount
                        class="border-2 border-primary-text-70 bg-primary-text-70 text-primary-background px-3 py-1.5 text-xs font-weight-navigation uppercase whitespace-nowrap transition-colors">
                        <span data-button-text>{{ 'sections.cart.apply_discount' | t }}</span>
                        <span class="loading-spinner">{%- render 'icon-ui-spinner' -%}</span>
                      </button>
                    </form>

                    <div data-discount-message class="text-sm hidden"></div>

                    {%- if block.settings.show_discount_chips -%}
                      {%- comment -%}Hybrid approach: Cart-level codes rendered in Liquid (cheap), line-level codes fetched via JS{%- endcomment -%}
                      <div class="cart-discount__codes flex flex-wrap gap-2 justify-center md:justify-end" data-discount-codes-container>
                        {%- for discount in cart.cart_level_discount_applications -%}
                          {%- if discount.type == 'discount_code' -%}
                            <button
                              type="button"
                              data-remove-discount="{{ discount.title }}"
                              class="discount-chip flex items-center gap-1.5 bg-primary-text-10 text-primary-text px-2 py-1 text-sm font-weight-navigation uppercase transition-colors cursor-pointer select-none"
                              aria-label="{{ 'sections.cart.remove_discount_code' | t: code: discount.title }}">
                              <span>{{ discount.title }}</span>
                              <svg class="w-3 h-3 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                                <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
                              </svg>
                            </button>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  </div>
                </cart-discount>
              </div>

            {%- when 'buttons' -%}
              <div class="cart-block__buttons space-y-3" {{ block.shopify_attributes }}>
                <div class="cart__checkout-buttons flex space-x-2 justify-center md:justify-end">
                  <noscript>
                    <button type="submit" class="cart__update-button button button--cta button--outline" form="cart">
                      {{ 'sections.cart.update' | t }}
                    </button>
                  </noscript>
                  <button type="submit" id="checkout" class="cart__checkout-button button button--cta button--solid" name="checkout"{% if cart == empty %} disabled{% endif %} form="cart">
                    {{ 'sections.cart.checkout' | t }}
                  </button>
                </div>
                {%- if additional_checkout_buttons and settings.show_accelerated_checkout -%}
                  <div class="cart__dynamic-checkout-buttons additional-checkout-buttons mx-auto max-w-md md:max-w-none">
                    {{ content_for_additional_checkout_buttons }}
                  </div>
                {%- endif -%}
              </div>
            {%- when 'agreement' -%}
              <cart-agreement class="cart-block__agreement text-primary-accent flex items-center space-x-2 justify-center md:justify-end" {{ block.shopify_attributes }}>
                <input class="" type="checkbox" checked name="cart-agreement" id="Cart-Agreement">
                <label class="text-primary-text p-0 text-sm font-body font-weight-body normal-case tracking-normal" for="Cart-Agreement">{{ block.settings.agreement_text }}</label>
              </cart-agreement>
          {%- endcase -%}
        {%- endfor -%}

        <div id="cart-errors"></div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main_cart_footer.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_notes",
      "label": "t:sections.main_cart_footer.settings.show_notes.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "subtotal",
      "name": "t:sections.main_cart_footer.blocks.subtotal.name",
      "limit": 1
    },
    {
      "type": "discount_code",
      "name": "t:sections.main_cart_footer.blocks.discount_code.name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_discount_chips",
          "label": "t:sections.main_cart_footer.blocks.discount_code.settings.show_discount_chips.label",
          "default": true
        }
      ]
    },
    {
      "type": "buttons",
      "name": "t:sections.main_cart_footer.blocks.buttons.name",
      "limit": 1
    },
    {
      "type": "agreement",
      "name": "t:sections.main_cart_footer.blocks.agreement.name",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "agreement_text",
          "label": "t:sections.main_cart_footer.blocks.agreement.settings.text.label",
          "default": "<p>I agree with the terms and conditions.</p>"
        }
      ]
    },
    {
      "type": "@app"
    },
    {
      "type": "custom_liquid",
      "name": "t:sections.main_cart_footer.blocks.custom_liquid.name",
      "settings": [
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "t:sections.main_cart_footer.blocks.custom_liquid.settings.custom_liquid.label",
          "info": "t:sections.main_cart_footer.blocks.custom_liquid.settings.custom_liquid.info"
        }
      ]
    }
  ]
}
{% endschema %}