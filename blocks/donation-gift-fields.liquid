{% assign uid = block.id | replace: '_', '' | downcase %}

{% style %}
  .donation-gift-fields-{{ uid }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
  }

  .donation-gift-fields__header-{{ uid }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    cursor: {% if block.settings.collapsible %}pointer{% else %}default{% endif %};
  }

  .donation-gift-fields__heading-{{ uid }} {
    margin: 0;
    font-size: 20px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
  }

  .donation-gift-fields__toggle-{{ uid }} {
    width: 24px;
    height: 24px;
    transition: transform 0.3s ease;
    color: {{ block.settings.text_color }};
  }

  .donation-gift-fields__toggle-{{ uid }}.collapsed {
    transform: rotate(-90deg);
  }

  .donation-gift-fields__content-{{ uid }} {
    display: block;
  }

  .donation-gift-fields__content-{{ uid }}.hidden {
    display: none;
  }

  .donation-gift-fields__field-{{ uid }} {
    margin-bottom: 24px;
  }

  .donation-gift-fields__label-{{ uid }} {
    display: block;
    margin-bottom: 8px;
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
  }

  .donation-gift-fields__input-{{ uid }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.input_background_color }};
    font-family: inherit;
  }

  .donation-gift-fields__input-{{ uid }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .donation-gift-fields__checkbox-group-{{ uid }} {
    margin-bottom: 24px;
  }

  .donation-gift-fields__checkbox-wrapper-{{ uid }} {
    display: flex;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .donation-gift-fields__checkbox-{{ uid }} {
    margin-right: 10px;
    margin-top: 2px;
    width: 18px;
    height: 18px;
    cursor: pointer;
    flex-shrink: 0;
  }

  .donation-gift-fields__checkbox-label-{{ uid }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    cursor: pointer;
    line-height: 1.5;
  }

  .donation-gift-fields__subsection-{{ uid }} {
    margin-bottom: 24px;
    padding: 20px;
    background-color: {{ block.settings.subsection_background_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
  }

  .donation-gift-fields__subsection-title-{{ uid }} {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 16px;
    color: {{ block.settings.text_color }};
  }

  .donation-gift-fields__honor-content-{{ uid }} {
    margin-top: 16px;
    padding-left: 28px;
  }

  .donation-gift-fields__honor-content-{{ uid }}.hidden {
    display: none;
  }

  .donation-gift-fields__support-checkboxes-{{ uid }} {
    margin-top: 16px;
  }

  .donation-gift-fields__hidden-{{ uid }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .donation-gift-fields-{{ uid }} {
      width: 100%;
      padding: {{ block.settings.padding | times: 0.75 }}px;
    }

    .donation-gift-fields__heading-{{ uid }} {
      font-size: 18px;
    }
  }
{% endstyle %}

<donation-gift-fields-{{ uid }}
  class="donation-gift-fields-{{ uid }}{% unless block.settings.always_show %} donation-gift-fields__hidden-{{ uid }}{% endunless %}"
  data-detection-type="{{ block.settings.detection_type }}"
  data-product-id="{{ block.settings.donation_product.id }}"
  data-product-type="{{ block.settings.donation_product_type }}"
  {{ block.shopify_attributes }}
>
  <div class="donation-gift-fields__header-{{ uid }}" data-header>
    <h2 class="donation-gift-fields__heading-{{ uid }}">{{ block.settings.section_heading }}</h2>
    {% if block.settings.collapsible %}
      <svg
        class="donation-gift-fields__toggle-{{ uid }}"
        data-toggle
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    {% endif %}
  </div>

  <div class="donation-gift-fields__content-{{ uid }}" data-content>
    <div class="donation-gift-fields__field-{{ uid }}">
      <label class="donation-gift-fields__label-{{ uid }}" for="donation-acknowledgement-{{ uid }}">
        Name(s) as you would like to be listed for gift acknowledgement
      </label>
      <input
        type="text"
        id="donation-acknowledgement-{{ uid }}"
        class="donation-gift-fields__input-{{ uid }}"
        data-property="acknowledgement_name"
      >
    </div>

    <div class="donation-gift-fields__subsection-{{ uid }}">
      <div class="donation-gift-fields__checkbox-wrapper-{{ uid }}">
        <input
          type="checkbox"
          id="donation-honor-toggle-{{ uid }}"
          class="donation-gift-fields__checkbox-{{ uid }}"
          data-honor-toggle
        >
        <label
          class="donation-gift-fields__checkbox-label-{{ uid }}"
          for="donation-honor-toggle-{{ uid }}"
        >
          In Honor Of
        </label>
      </div>

      <div class="donation-gift-fields__honor-content-{{ uid }} hidden" data-honor-content>
        <label class="donation-gift-fields__label-{{ uid }}" for="donation-honor-name-{{ uid }}">
          Name
        </label>
        <input
          type="text"
          id="donation-honor-name-{{ uid }}"
          class="donation-gift-fields__input-{{ uid }}"
          data-property="in_honor_of_name"
        >
      </div>
    </div>

    <div class="donation-gift-fields__subsection-{{ uid }}">
      <div class="donation-gift-fields__subsection-title-{{ uid }}">
        I would like my gift to support
      </div>
      <div class="donation-gift-fields__support-checkboxes-{{ uid }}">
        <div class="donation-gift-fields__checkbox-wrapper-{{ uid }}">
          <input
            type="checkbox"
            id="donation-exhibitions-{{ uid }}"
            class="donation-gift-fields__checkbox-{{ uid }}"
            data-property="support_exhibitions_fund"
            value="Exhibitions Fund"
          >
          <label
            class="donation-gift-fields__checkbox-label-{{ uid }}"
            for="donation-exhibitions-{{ uid }}"
          >
            Exhibitions Fund
          </label>
        </div>

        <div class="donation-gift-fields__checkbox-wrapper-{{ uid }}">
          <input
            type="checkbox"
            id="donation-education-{{ uid }}"
            class="donation-gift-fields__checkbox-{{ uid }}"
            data-property="support_education_fund"
            value="Education Fund"
          >
          <label
            class="donation-gift-fields__checkbox-label-{{ uid }}"
            for="donation-education-{{ uid }}"
          >
            Education Fund
          </label>
        </div>

        <div class="donation-gift-fields__checkbox-wrapper-{{ uid }}">
          <input
            type="checkbox"
            id="donation-annual-{{ uid }}"
            class="donation-gift-fields__checkbox-{{ uid }}"
            data-property="support_annual_fund"
            value="Annual Fund"
          >
          <label
            class="donation-gift-fields__checkbox-label-{{ uid }}"
            for="donation-annual-{{ uid }}"
          >
            Annual Fund
          </label>
        </div>

        <div class="donation-gift-fields__checkbox-wrapper-{{ uid }}">
          <input
            type="checkbox"
            id="donation-sculpture-{{ uid }}"
            class="donation-gift-fields__checkbox-{{ uid }}"
            data-property="support_sculpture_garden_fund"
            value="Sculpture Garden Fund"
          >
          <label
            class="donation-gift-fields__checkbox-label-{{ uid }}"
            for="donation-sculpture-{{ uid }}"
          >
            Sculpture Garden Fund
          </label>
        </div>

        <div class="donation-gift-fields__checkbox-wrapper-{{ uid }}">
          <input
            type="checkbox"
            id="donation-other-{{ uid }}"
            class="donation-gift-fields__checkbox-{{ uid }}"
            data-property="support_other"
            value="Other"
          >
          <label
            class="donation-gift-fields__checkbox-label-{{ uid }}"
            for="donation-other-{{ uid }}"
          >
            Other
          </label>
        </div>
      </div>
    </div>

    <div class="donation-gift-fields__checkbox-wrapper-{{ uid }}">
      <input
        type="checkbox"
        id="donation-anonymous-{{ uid }}"
        class="donation-gift-fields__checkbox-{{ uid }}"
        data-property="make_gift_anonymously"
        value="Yes"
      >
      <label
        class="donation-gift-fields__checkbox-label-{{ uid }}"
        for="donation-anonymous-{{ uid }}"
      >
        Make this gift anonymously
      </label>
    </div>

    <div class="donation-gift-fields__checkbox-wrapper-{{ uid }}">
      <input
        type="checkbox"
        id="donation-matching-{{ uid }}"
        class="donation-gift-fields__checkbox-{{ uid }}"
        data-property="employer_matching_gift_form_submitted"
        value="Yes"
      >
      <label
        class="donation-gift-fields__checkbox-label-{{ uid }}"
        for="donation-matching-{{ uid }}"
      >
        I have submitted an Employer's Matching Gift Form
      </label>
    </div>
  </div>
</donation-gift-fields-{{ uid }}>

<script>
  (function() {
    class DonationGiftFields{{ uid }} extends HTMLElement {
      constructor() {
        super();
        this.detectionType = this.dataset.detectionType;
        this.productId = this.dataset.productId;
        this.productType = this.dataset.productType;
        this.donationLineKey = null;
        this.existingProperties = {};
        this.alwaysShow = {{ block.settings.always_show | json }};
        this.storageKey = 'donation_gift_fields';
        this.storedSynced = false;
        this.debug = {{ block.settings.debug | json }};
        this.isCollapsible = {{ block.settings.collapsible | json }};
        this.isCollapsed = false;
      }

      log(...args) {
        if (this.debug) console.log('[donation-gift-fields]', ...args);
      }

      ourPropertyNames() {
        return Array.from(this.querySelectorAll('[data-property]'))
          .map(input => input.dataset.property);
      }

      findDonationLine(cart) {
        if (this.detectionType === 'product' && this.productId) {
          return cart.items.find(item => item.product_id.toString() === this.productId) || null;
        }
        if (this.detectionType === 'type' && this.productType) {
          return cart.items.find(item => item.product_type && item.product_type === this.productType) || null;
        }
        return null;
      }

      connectedCallback() {
        this.loadStoredValues();
        this.checkCartForDonation();
        this.setupEventListeners();
        this.setupCollapsible();

        document.addEventListener('cart:updated', () => {
          this.checkCartForDonation();
        });
      }

      setupCollapsible() {
        if (!this.isCollapsible) return;

        const header = this.querySelector('[data-header]');
        const toggle = this.querySelector('[data-toggle]');
        const content = this.querySelector('[data-content]');

        if (header && toggle && content) {
          header.addEventListener('click', () => {
            this.isCollapsed = !this.isCollapsed;
            toggle.classList.toggle('collapsed', this.isCollapsed);
            content.classList.toggle('hidden', this.isCollapsed);
          });
        }
      }

      async checkCartForDonation() {
        try {
          const response = await fetch('/cart.js');
          const cart = await response.json();

          const donationLine = this.findDonationLine(cart);

          this.log('detection', {
            type: this.detectionType,
            productId: this.productId,
            productType: this.productType,
            cartItems: cart.items.map(i => ({ product_id: i.product_id, product_type: i.product_type, title: i.title })),
            matched: donationLine ? donationLine.key : null
          });

          if (donationLine) {
            this.donationLineKey = donationLine.key;
            this.existingProperties = donationLine.properties || {};
            this.classList.remove('donation-gift-fields__hidden-{{ uid }}');
            this.loadExistingProperties(donationLine.properties);
            this.syncStoredToCart();
          } else {
            this.donationLineKey = null;
            if (!this.alwaysShow) {
              this.classList.add('donation-gift-fields__hidden-{{ uid }}');
            }
          }
        } catch (error) {
          console.error('Error checking cart for donation:', error);
        }
      }

      loadExistingProperties(properties) {
        if (!properties) return;

        const inputs = this.querySelectorAll('[data-property]');
        inputs.forEach(input => {
          const propertyName = input.dataset.property;
          // Only override a field when the cart line actually has this property,
          // so values pre-filled from localStorage (donation page) are preserved.
          if (!(propertyName in properties)) return;
          const propertyValue = properties[propertyName];

          if (input.type === 'checkbox') {
            input.checked = propertyValue === input.value || propertyValue === 'Yes';
          } else {
            input.value = propertyValue || '';
          }
        });

        const honorToggle = this.querySelector('[data-honor-toggle]');
        const honorContent = this.querySelector('[data-honor-content]');
        if (honorToggle && honorContent && properties.in_honor_of_name) {
          honorToggle.checked = true;
          honorContent.classList.remove('hidden');
        }
      }

      setupEventListeners() {
        const textInputs = this.querySelectorAll('input[type="text"]');
        textInputs.forEach(input => {
          // Persist locally on every keystroke so values survive the DONATE redirect,
          // and push to the cart line (if any) once the field is committed.
          input.addEventListener('input', () => this.saveStoredValues());
          input.addEventListener('change', () => this.onFieldChange());
        });

        const checkboxes = this.querySelectorAll('input[type="checkbox"][data-property]');
        checkboxes.forEach(checkbox => {
          checkbox.addEventListener('change', () => this.onFieldChange());
        });

        const honorToggle = this.querySelector('[data-honor-toggle]');
        const honorContent = this.querySelector('[data-honor-content]');
        if (honorToggle && honorContent) {
          honorToggle.addEventListener('change', () => {
            honorContent.classList.toggle('hidden', !honorToggle.checked);
            if (!honorToggle.checked) {
              const honorNameInput = honorContent.querySelector('input');
              if (honorNameInput) {
                honorNameInput.value = '';
              }
            }
            this.onFieldChange();
          });
        }
      }

      onFieldChange() {
        this.saveStoredValues();
        this.updateCartProperties();
      }

      collectProperties() {
        const properties = {};
        const inputs = this.querySelectorAll('[data-property]');

        inputs.forEach(input => {
          const propertyName = input.dataset.property;

          if (input.type === 'checkbox') {
            if (input.checked) {
              properties[propertyName] = input.value || 'Yes';
            }
          } else if (input.type === 'text') {
            if (input.value.trim()) {
              properties[propertyName] = input.value.trim();
            }
          }
        });

        return properties;
      }

      loadStoredValues() {
        let stored;
        try {
          stored = JSON.parse(localStorage.getItem(this.storageKey) || '{}');
        } catch (error) {
          stored = {};
        }
        if (!stored || typeof stored !== 'object') return;

        const inputs = this.querySelectorAll('[data-property]');
        inputs.forEach(input => {
          const propertyName = input.dataset.property;
          if (!(propertyName in stored)) return;
          const storedValue = stored[propertyName];

          if (input.type === 'checkbox') {
            input.checked = storedValue === input.value || storedValue === 'Yes';
          } else {
            input.value = storedValue || '';
          }
        });

        const honorToggle = this.querySelector('[data-honor-toggle]');
        const honorContent = this.querySelector('[data-honor-content]');
        if (honorToggle && honorContent && stored.in_honor_of_name) {
          honorToggle.checked = true;
          honorContent.classList.remove('hidden');
        }
      }

      saveStoredValues() {
        try {
          localStorage.setItem(this.storageKey, JSON.stringify(this.collectProperties()));
        } catch (error) {
          // Storage may be unavailable (private mode / quota) — fail silently.
        }
      }

      // On the cart page the donation line now exists; push the values entered on
      // the donation page (carried via localStorage) onto that line. Runs once.
      syncStoredToCart() {
        if (this.storedSynced || !this.donationLineKey) return;
        this.storedSynced = true;
        if (Object.keys(this.collectProperties()).length === 0) return;
        this.updateCartProperties();
      }

      async updateCartProperties() {
        if (!this.donationLineKey) return;

        // Start from the line's existing properties so we don't wipe values set by
        // the donation app (e.g. the donation amount). Clear only the fields we own,
        // then apply the current form state — /cart/change.js REPLACES all properties.
        const merged = Object.assign({}, this.existingProperties);
        this.ourPropertyNames().forEach(name => { delete merged[name]; });
        Object.assign(merged, this.collectProperties());

        try {
          const response = await fetch('/cart/change.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              id: this.donationLineKey,
              properties: merged
            })
          });

          if (!response.ok) {
            const body = await response.text();
            console.error('[donation-gift-fields] /cart/change.js failed', response.status, body);
            return;
          }

          // Changing properties gives the line a NEW key — refresh it (and cached
          // properties) from the returned cart so later edits target the live line.
          const cart = await response.json();
          const refreshed = this.findDonationLine(cart);
          if (refreshed) {
            this.donationLineKey = refreshed.key;
            this.existingProperties = refreshed.properties || {};
          }

          this.log('saved properties', merged);
          document.dispatchEvent(new CustomEvent('cart:updated'));
        } catch (error) {
          console.error('Error updating cart properties:', error);
        }
      }
    }

    customElements.define('donation-gift-fields-{{ uid }}', DonationGiftFields{{ uid }});
  })();
</script>

{% schema %}
{
  "name": "Donation gift fields",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Detection settings"
    },
    {
      "type": "select",
      "id": "detection_type",
      "label": "Detect donation by",
      "options": [
        {
          "value": "product",
          "label": "Specific product"
        },
        {
          "value": "type",
          "label": "Product type"
        }
      ],
      "default": "product"
    },
    {
      "type": "product",
      "id": "donation_product",
      "label": "Donation product",
      "info": "Used when detection type is 'Specific product'"
    },
    {
      "type": "text",
      "id": "donation_product_type",
      "label": "Donation product type",
      "info": "Used when detection type is 'Product type'. Must match the product's Type field exactly.",
      "default": "Donation"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section heading",
      "default": "Gift Information"
    },
    {
      "type": "checkbox",
      "id": "always_show",
      "label": "Always show fields",
      "info": "Show the fields even when no donation is in the cart yet. Turn ON for the donation page (above the widget); can be OFF on the cart page.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "collapsible",
      "label": "Make section collapsible",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "debug",
      "label": "Debug logging",
      "info": "Logs detection and save activity to the browser console. Turn off in production.",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#E5E5E5"
    },
    {
      "type": "color",
      "id": "subsection_background_color",
      "label": "Subsection background",
      "default": "#FAFAFA"
    },
    {
      "type": "header",
      "content": "Input fields"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "Input background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Input border",
      "default": "#E5E5E5"
    },
    {
      "type": "color",
      "id": "input_focus_border_color",
      "label": "Input focus border",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "label": "Input border radius",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    }
  ],
  "presets": [
    {
      "name": "Donation gift fields"
    }
  ]
}
{% endschema %}
